generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  role         Role      @default(CUSTOMER)
  phone        String?   @unique
  profileImage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  status       String    @default("active")
  name         Json?
  articles     Article[]
  cart         Cart?
  customer     Customer?
  farmer       Farmer?
  reviews      Review[]
  wishlist     Wishlist?
}

model Customer {
  id                 String              @id @default(cuid())
  userId             String              @unique
  addresses          Address[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders             Order[]
  customerMetafields CustomerMetafield[]
}

model Address {
  id           String   @id @default(cuid())
  customerId   String
  type         String   @default("Home")
  phoneNumber  String
  pincode      String
  isDefault    Boolean  @default(false)
  fullName     Json
  addressLine1 Json
  addressLine2 Json?
  landmark     Json?
  city         Json
  state        Json
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Farmer {
  id          String            @id @default(cuid())
  userId      String            @unique
  landSize    Float?
  farmDetails Json?
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  images      Image[]
  products    Product[]
  reviews     Review[]          @relation("FarmerReviews")
  metafields  FarmerMetafield[]
}

model Vendor {
  id              String            @id @default(cuid())
  email           String            @unique
  password        String
  phone           String?           @unique
  profileImage    String?
  logo            String?
  commissionRate  Float             @default(0.0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  businessSlug    String            @unique
  name            Json?
  businessName    Json
  description     Json?
  serviceArea     Json?
  status          String            @default("active")
  images          Image[]
  products        Product[]
  productRequests ProductRequest[]
  reviews         Review[]          @relation("VendorReviews")
  metafields      VendorMetafield[]
}

model ProductRequest {
  id        String        @id @default(cuid())
  vendorId  String
  productId String
  quantity  Int
  status    RequestStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  product   Product       @relation(fields: [productId], references: [id])
  vendor    Vendor        @relation(fields: [vendorId], references: [id])
}

model Product {
  id                String             @id @default(cuid())
  slug              String             @unique
  price             Float
  compareAtPrice    Float?
  costPerItem       Float?
  sku               String?            @unique
  barcode           String?
  weight            Float?
  isTaxable         Boolean            @default(true)
  status            ProductStatus      @default(DRAFT)
  categoryId        String?
  vendorId          String?
  farmerId          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tags              String?
  name              Json
  shortDesc         Json?
  description       Json?
  isRecommendation  Boolean            @default(false)
  metaDescription   Json?
  metaTitle         Json?
  options           Json?
  taxRate           Float              @default(5.0)
  shippingProfileId String?
  shippingProfile   ShippingProfile?   @relation(fields: [shippingProfileId], references: [id])
  cartItems         CartItem[]
  images            Image[]
  inventoryItems    InventoryItem[]
  orderItems        OrderItem[]
  category          Category?          @relation(fields: [categoryId], references: [id])
  farmer            Farmer?            @relation(fields: [farmerId], references: [id])
  vendor            Vendor?            @relation(fields: [vendorId], references: [id])
  metafields        ProductMetafield[]
  productRequests   ProductRequest[]
  variants          ProductVariant[]
  reviews           Review[]           @relation("ProductReviews")
  wishlistItems     WishlistItem[]
  offers            Offer[]            @relation("OfferToProduct")
}

model ShippingProfile {
  id        String         @id @default(cuid())
  name      String         @unique
  isDefault Boolean        @default(false)
  products  Product[]
  zones     ShippingZone[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ShippingZone {
  id        String          @id @default(cuid())
  profileId String
  name      String
  countries Json // Array of country codes/names
  states    Json? // Array of state codes/names
  isActive  Boolean         @default(true)
  profile   ShippingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rates     ShippingRate[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ShippingRate {
  id        String       @id @default(cuid())
  zoneId    String
  name      String
  type      RateType     @default(FLAT)
  price     Float
  minWeight Float?       @default(0)
  maxWeight Float?
  minPrice  Float?       @default(0)
  maxPrice  Float?
  zone      ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model LocalDeliverySetting {
  id             String   @id @default(cuid())
  isActive       Boolean  @default(false)
  deliveryRadius Float?   @default(10) // in km
  minOrderAmount Float?   @default(0)
  deliveryCharge Float?   @default(0)
  pincodes       Json? // Specific pincodes for local delivery
  updatedAt      DateTime @updatedAt
}

model LocalPickupSetting {
  id           String   @id @default(cuid())
  isActive     Boolean  @default(false)
  locationName String?
  instructions String?
  updatedAt    DateTime @updatedAt
}

model ShippingPackage {
  id         String   @id @default(cuid())
  name       String
  width      Float
  height     Float
  length     Float
  weight     Float    @default(0)
  unit       String   @default("in")
  weightUnit String   @default("lb")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum RateType {
  FLAT
  WEIGHT_BASED
}

model ProductMetafield {
  id        String   @id @default(cuid())
  productId String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, namespace, key])
}

model CategoryMetafield {
  id         String   @id @default(cuid())
  categoryId String
  namespace  String
  key        String
  value      String
  type       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, namespace, key])
}

model CustomerMetafield {
  id         String   @id @default(cuid())
  customerId String
  namespace  String
  key        String
  value      String
  type       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, namespace, key])
}

model BlogMetafield {
  id        String   @id @default(cuid())
  blogId    String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, namespace, key])
}

model ArticleMetafield {
  id        String   @id @default(cuid())
  articleId String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, namespace, key])
}

model PageMetafield {
  id        String   @id @default(cuid())
  pageId    String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, namespace, key])
}

model ProductVariantMetafield {
  id        String         @id @default(cuid())
  variantId String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, namespace, key])
}

model OrderMetafield {
  id        String   @id @default(cuid())
  orderId   String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, namespace, key])
}

model FarmerMetafield {
  id        String   @id @default(cuid())
  farmerId  String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farmer    Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@unique([farmerId, namespace, key])
}

model VendorMetafield {
  id        String   @id @default(cuid())
  vendorId  String
  namespace String
  key       String
  value     String
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, namespace, key])
}

model WarehouseMetafield {
  id          String    @id @default(cuid())
  warehouseId String
  namespace   String
  key         String
  value       String
  type        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, namespace, key])
}

model Category {
  id           String              @id @default(cuid())
  slug         String              @unique
  image        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  name         Json
  description  Json?
  icon         String?
  displayImage String?
  products     Product[]
  metafields   CategoryMetafield[]
}

model ProductVariant {
  id             String                    @id @default(cuid())
  productId      String
  title          String
  sku            String?                   @unique
  barcode        String?
  price          Float
  compareAtPrice Float?
  costPerItem    Float?
  weight         Float?
  quantity       Int                       @default(0)
  options        Json?
  isDefault      Boolean                   @default(false)
  isActive       Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  inventoryItems InventoryItem[]
  product        Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  metafields     ProductVariantMetafield[]
}

model Warehouse {
  id             String               @id @default(cuid())
  pincode        String
  name           Json
  locationName   Json?
  address        Json?
  images         Image[]
  inventoryItems InventoryItem[]
  metafields     WarehouseMetafield[]
}

model InventoryItem {
  id          String          @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int             @default(0)
  updatedAt   DateTime        @updatedAt
  variantId   String?
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId, variantId])
}

model PincodeData {
  id       String  @id @default(cuid())
  pincode  String  @unique
  district String
  state    String
  city     String
  area     String?
}

model Area {
  id             String   @id @default(cuid())
  pincode        String
  deliveryCharge Float    @default(0)
  minOrderAmount Float    @default(0)
  status         String   @default("active")
  pincodeDataId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  areaName       Json
  city           Json
  district       Json?
  state          Json?
}

model Offer {
  id           String       @id @default(cuid())
  discountType DiscountType
  value        Float
  startTime    DateTime
  endTime      DateTime
  isActive     Boolean      @default(true)
  name         Json
  description  Json?
  showInHero   Boolean      @default(false)
  slug         String       @unique @default("temporary-slug")
  images       Image[]
  products     Product[]    @relation("OfferToProduct")
}

model Event {
  id          String   @id @default(cuid())
  date        DateTime
  createdAt   DateTime @default(now())
  title       Json
  shortDesc   Json
  description Json
  location    Json?
  slug        String?  @unique @default(cuid())
  images      Image[]
}

model Review {
  id        String       @id @default(cuid())
  rating    Int
  authorId  String
  productId String?
  vendorId  String?
  farmerId  String?
  createdAt DateTime     @default(now())
  comment   Json?
  status    ReviewStatus @default(PENDING)
  author    User         @relation(fields: [authorId], references: [id])
  farmer    Farmer?      @relation("FarmerReviews", fields: [farmerId], references: [id])
  product   Product?     @relation("ProductReviews", fields: [productId], references: [id])
  vendor    Vendor?      @relation("VendorReviews", fields: [vendorId], references: [id])
}

model Image {
  id          String     @id @default(cuid())
  url         String
  productId   String?
  farmerId    String?
  eventId     String?
  warehouseId String?
  vendorId    String?
  createdAt   DateTime   @default(now())
  altText     Json?
  offerId     String?
  event       Event?     @relation(fields: [eventId], references: [id])
  farmer      Farmer?    @relation(fields: [farmerId], references: [id])
  offer       Offer?     @relation(fields: [offerId], references: [id])
  product     Product?   @relation(fields: [productId], references: [id])
  vendor      Vendor?    @relation(fields: [vendorId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
}

model Translation {
  id        String   @id @default(cuid())
  language  String
  key       String
  value     String
  context   String?
  targetId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                 String           @id @default(cuid())
  orderNumber        String?          @unique
  customerId         String?
  total              Float
  status             OrderStatus      @default(PENDING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  pincode            String?
  shippingAddress    String?
  customerName       String?
  customerPhone      String?
  subtotal           Float?           @default(0.0)
  taxAmount          Float            @default(0.0)
  shippingMethodName String?
  shippingCharge     Float            @default(0.0)
  trackingNumber     String?
  trackingUrl        String?
  carrierName        String?
  shippedAt          DateTime?
  customer           Customer?        @relation(fields: [customerId], references: [id])
  items              OrderItem[]
  metafields         OrderMetafield[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  taxAmount Float?  @default(0.0)
  taxRate   Float?  @default(0.0)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Blog {
  id              String          @id @default(cuid())
  title           Json
  handle          String          @unique
  description     Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  metaDescription Json?
  metaTitle       Json?
  articles        Article[]
  metafields      BlogMetafield[]
}

model Article {
  id              String             @id @default(cuid())
  blogId          String
  title           Json
  handle          String             @unique
  authorId        String
  tags            String?
  image           String?
  metaTitle       Json?
  metaDescription Json?
  status          BlogStatus         @default(DRAFT)
  publishedAt     DateTime?
  views           Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  bodyHtml        Json
  featured        Boolean            @default(false)
  imageAlt        Json?
  summaryHtml     Json?
  author          User               @relation(fields: [authorId], references: [id])
  blog            Blog               @relation(fields: [blogId], references: [id], onDelete: Cascade)
  metafields      ArticleMetafield[]
}

model Page {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           Json
  content         Json
  status          PageStatus      @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  metaTitle       Json?
  metaDescription Json?
  metafields      PageMetafield[]
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, variantId])
}

model UserOtp {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model StoreSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum Role {
  ADMIN
  CUSTOMER
  FARMER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  COMBO
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model MetafieldDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String // e.g., "single_line", "multi_line", "integer", "decimal", "date", etc.
  ownerType   String // e.g., "PRODUCT", "VARIANT", "COLLECTION", "CUSTOMER", etc.
  quantity    String   @default("ONE") // "ONE" or "LIST"
  namespace   String   @default("custom")
  key         String // e.g., "material_type"
  pinned      Boolean  @default(true)
  options     Json? // e.g., { storefrontApiAccess: true }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerType, namespace, key])
}

model MetaobjectDefinition {
  id          String            @id @default(cuid())
  name        String            @unique
  type        String            @unique // e.g., "cart_upsell", "fabric_colors"
  description String?
  fields      MetaobjectField[]
  metaobjects Metaobject[]
  options     Json? // e.g., { status: true, translations: true }
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model MetaobjectField {
  id           String               @id @default(cuid())
  definitionId String
  name         String
  type         String // field type like "single_line", "integer", etc.
  quantity     String               @default("ONE")
  definition   MetaobjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Metaobject {
  id           String               @id @default(cuid())
  definitionId String
  handle       String
  data         Json // The actual data stored for this metaobject instance
  definition   MetaobjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([definitionId, handle])
}
